    "package_type": {
      "type": "string"
    },
    "workload_scale": {
      "type": "integer"
    },
    "n": {
      "type": "integer"
    },
    "R_hor": {
      "type": "integer"
    },
    "R_car": {
      "type": "integer"
    },
    "k_min": {
      "type": "integer"
    },
    "k_run": {
      "type": "integer"
    },
    "logical_lookup_cells": {
      "type": "integer"
    },
    "logical_mul_constraints": {
      "type": "integer"
    },
    "logical_lin_constraints": {
      "type": "integer"
    },
    "physical_rows": {
      "type": "integer"
    },
